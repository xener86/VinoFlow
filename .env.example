# VinoFlow - Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# ────────────────────────────────────────────
# Database (PostgreSQL)
# ────────────────────────────────────────────
POSTGRES_USER=vinoflow
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=vinoflow
DATABASE_URL=postgresql://vinoflow:change_me_to_a_strong_password@db:5432/vinoflow

# ────────────────────────────────────────────
# Backend
# ────────────────────────────────────────────
PORT=3100
NODE_ENV=production

# Generate a long random string (e.g. `openssl rand -base64 48`)
# The backend WILL NOT START with a missing or default JWT_SECRET
JWT_SECRET=replace_with_a_long_random_string_min_32_chars

# URL where your frontend is accessible (used for CORS)
FRONTEND_URL=http://localhost:5001

# ────────────────────────────────────────────
# AI Providers (Sommelier v2)
# ────────────────────────────────────────────
# At least one provider must be configured to use the sommelier.
# Defaults: Gemini Flash for criteria extraction, Claude Sonnet for argumentation.

# Google Gemini — https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude — https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Override defaults per task (optional)
# VINOFLOW_PROVIDER_EXTRACT_CRITERIA=gemini
# VINOFLOW_PROVIDER_ARGUE=claude
# VINOFLOW_PROVIDER_ENRICH=claude
